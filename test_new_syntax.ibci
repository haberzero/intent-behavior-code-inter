import sys
import ai
import json
import file

# 1. 配置加载
dict config = json.parse(file.read((str)sys.script_dir() + "/api_config.json"))
dict default_model = (dict) config["default_model"]
ai.set_config((str)default_model["base_url"], (str)default_model["api_key"], (str)default_model["model"])

print("--- [NEW SYNTAX TEST] ---")

# 1. 测试 for @~ ... ~: (条件驱动模式)
print("\n[Test 1] Condition-driven For Loop:")
int count = 0
# 只要 AI 觉得 count 还没到 3，就继续循环
for @~ $count 小于 3 吗？只答 1/0 ~:
    count = count + 1
    print("Looping... count = " + (str)count)

# 3. 测试复杂目标的 For 循环变量提取 (IES 2.2 Fix)
print("\n[Test 3] Complex Target For Loop:")
list names = ["Alice", "Bob"]
for str name in names:
    print("Name: " + name)

list coords = [[1, 2], [3, 4]]
# 测试元组解包 (IES 2.2 Fix)
for (x, y) in coords:
    print("Coord (untyped): " + (str)x + "," + (str)y)

# 测试带类型标注的元组解包 (IES 2.2 NEW)
for (int cx, int cy) in coords:
    print("Coord (typed): " + (str)cx + "," + (str)cy)

# 2. 测试 llmretry 语法糖
print("\n[Test 2] llmretry Syntactic Sugar:")
# 使用 MOCK:FAIL 强制触发一次模糊判定，触发 llmretry
# [FIX] llmretry 必须位于语句之后，这里我们用一个赋值语句来承载行为描述
str res = @~ MOCK:FAIL 返回一个模糊的结果 ~
llmretry "请务必返回 1 或 0"
print("Result after retry: " + res)

print("\n--- [TEST COMPLETE] ---")
