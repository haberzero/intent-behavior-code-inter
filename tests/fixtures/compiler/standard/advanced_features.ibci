# IBCI Advanced Features Suite
# Covers: LLM Functions, Intents, Behavior Expressions, Parameter Injection

# 1. LLM Function Definition with System & User Prompts
llm translate(str text) -> str:
__sys__
You are a professional translator.
Translate the following text accurately.
__user__
Input text: $__text__
llmend

# 2. Intent Comments (Modes: !, -, +, @)
@! behave as a polite assistant
str greeting = @~ say hello to user ~

@+ detailed explanation
func explain_concept(str topic):
    # Intent can also be inside function body
    @- briefly
    str summary = @~ summarize $topic ~
    print(summary)

# 3. Behavior Expression with Tagging
str prompt = @prompt~ write a story about $greeting ~

# 4. LLM Except Fallback
int score = 10
llmexcept:
    print("Repairing score...")
