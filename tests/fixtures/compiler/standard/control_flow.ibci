# IBCI Control Flow Fixture
# Responsibility: If, while, for loops, and exception handling.

int val = 15
int local_var = 0

if val > 10:
    local_var = val + 5
else:
    local_var = val - 5

# Loops and Inference
for i in range(10):
    int x = i
    if i % 2 == 0:
        print("Even")

# Error Handling (Try-Except)
try:
    int result = 10 / 0
except Exception as e:
    print("Caught error")
