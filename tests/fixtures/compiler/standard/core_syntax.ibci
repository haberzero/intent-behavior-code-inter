# IBCI Standard Syntax Suite
# Covers: Basic Types, Control Flow, Function & Class Defs, Scopes, Inheritance

# 1. Basic Variable Declarations
int a = 10
str b = "hello"
float c = 3.14
bool d = True
none n = None

# 2. Function Definitions (Simple to Complex)
func add(int x, int y) -> int:
    return x + y

func compute_with_scope(int val) -> int:
    int local_var = val * 2
    if val > 10:
        local_var = local_var + 5
    else:
        local_var = local_var - 5
    return local_var

# 3. Class Definitions and Inheritance
class Animal:
    str name
    int age
    
    func __init__(str n, int a):
        self.name = n
        self.age = a
    
    func speak() -> str:
        return "Generic Sound"

class Dog(Animal):
    str breed
    
    func __init__(str n, int a, str b):
        self.name = n
        self.age = a
        self.breed = b
        
    func speak() -> str:
        return "Woof!"

# 4. OOP Assignments & Logic
Animal my_pet = Dog("Buddy", 3, "Golden Retriever")
str pet_sound = my_pet.speak()

# 5. Loops and Inference
for i in 10.to_list():
    var x = i
    if i % 2 == 0:
        # print("Even")
        pass

# 6. Error Handling (Try-Except)
try:
    int result = 10 / 0
except Exception as e:
    # print("Caught error")
    pass
