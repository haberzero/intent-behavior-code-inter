# AI 基础使用

print("=== AI 模块基础使用 ===")

import ai

print("\n[注意] 此示例需要配置 LLM API 密钥才能运行")
print("[提示] 设置环境变量: export OPENAI_API_KEY=your_key")

print("\n=== AI 基础调用 ===")

# 简单对话
str prompt = "请用一句话介绍 IBCI 编程语言"
print("问题: " + prompt)

# 基本对话调用
# str response = ai.chat(prompt)
# print("回答: " + response)

print("\n[已注释] ai.chat() 调用需要 API 密钥")

print("\n=== AI 函数调用 ===")

# 使用 AI 函数进行更复杂的任务
# #@ 让 AI 帮我们生成代码
# str code_template = ai.generate_code(
#     "生成一个计算斐波那契数列的 IBCI 函数"
# )
# print("生成的代码:")
# print(code_template)

print("\n[已注释] ai.generate_code() 调用需要 API 密钥")

print("\n=== 配置检查 ===")

# 检查是否配置了 API 密钥
bool has_key = ai.has_api_key()
print("API 密钥已配置: " + (str)has_key)

if has_key:
    print("可以正常使用 AI 功能")
else:
    print("请先配置 API 密钥")

print("\n=== AI 模块方法列表 ===")
print("ai.chat(prompt) - 简单对话")
print("ai.analyze(text) - 文本分析")
print("ai.generate_code(template) - 代码生成")
print("ai.translate(text, target_lang) - 翻译")
print("ai.summarize(text) - 文本摘要")
print("ai.extract_keywords(text) - 关键词提取")
