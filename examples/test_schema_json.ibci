import ai
import json
ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("=== JSON 模块测试 ===")

# 1. JSON parse
str json_str = '{"name": "Alice", "age": 30, "active": true}'
any parsed = json.parse(json_str)
print("parsed type: " + (str)(parsed is not None))
any name = parsed["name"]
print("name: " + (str)name)
any age = parsed["age"]
print("age: " + (str)age)

# 2. JSON stringify
dict d = {"key": "value", "num": 42}
str json_out = json.stringify(d)
print("json_out: " + json_out)

# 3. Nested JSON
str nested_json = '{"user": {"id": 1, "tags": ["a", "b"]}}'
any nested = json.parse(nested_json)
any user = nested["user"]
print("user.id: " + (str)user["id"])

print("=== JSON 测试完成 ===")
