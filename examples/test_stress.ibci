import ai
ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("=== 压力测试与边界 ===")

# 1. Deep recursion
func fib(int n) -> int:
    if n <= 1:
        return n
    return fib(n-1) + fib(n-2)
print("fib(15) = " + (str)(fib(15)))

# 2. Large list operations
list[int] big = []
int i = 0
while i < 100:
    big.append(i * i)
    i = i + 1
print("big list len: " + (str)(big.len()))
print("big[99] = " + (str)(big[99]))

# 3. Large dict
dict d = {}
int j = 0
while j < 50:
    str key = "k" + (str)j
    d[key] = j * 2
    j = j + 1
print("dict len: " + (str)(d.len()))

# 4. Nested loops
int nested_sum = 0
int a = 0
while a < 10:
    int b = 0
    while b < 10:
        nested_sum = nested_sum + 1
        b = b + 1
    a = a + 1
print("nested 10*10 = " + (str)nested_sum)

# 5. Exception propagation through function calls
func risky(int x) -> int:
    if x == 0:
        raise Exception("zero!")
    return 100 / x

func safe_call(int x) -> str:
    try:
        int r = risky(x)
        return (str)r
    except Exception as e:
        return "caught: " + e.message

print("safe_call(0): " + safe_call(0))
print("safe_call(5): " + safe_call(5))

# 6. Object deep nesting
class Wrapper:
    any value
    
    func __init__(self, any v):
        self.value = v

Wrapper w1 = Wrapper(42)
Wrapper w2 = Wrapper(w1)
print("w2.value type is Wrapper: " + (str)(w2.value is not None))

# 7. Multiple LLM calls with state
int llm_count = 0
list[str] results = []
int k = 0
while k < 3:
    str r = @~ MOCK:SEQ:[a,b,c] seq_stress ~
    results.append(r)
    llm_count = llm_count + 1
    k = k + 1
print("llm_count: " + (str)llm_count)
print("results: " + (str)results)

# 8. String operations stress
str long_str = "a" * 100
print("long str len: " + (str)(long_str.len()))
bool starts = long_str.startswith("a")
bool ends = long_str.endswith("a")
print("starts/ends with a: " + (str)starts + "/" + (str)ends)

# 9. AugAssign patterns
int aug = 10
aug = aug + 5
print("aug after +5: " + (str)aug)

# 10. Chained method calls
str chain = "  hello world  ".trim().to_upper().replace("WORLD", "IBCI")
print("chain: " + chain)

print("=== 压力测试完成 ===")
