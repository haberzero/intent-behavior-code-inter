import ai
import file
import json

# 情况 1：显式加载本目录下的配置
# 
# 运行方式：
# python main.py run examples/05_llm_config/01_cli_config.ibci

print("--- [01_cli_config.ibci] ---")

str config_path = __dir__ + "/api_config.json"
print("Loading config from: " + config_path)

# 检查变量是否已由 main.py 注入
try:
    dict config = json.parse(file.read(config_path))
    str url = (str) config["url"]
    str key = (str) config["key"]
    str model = (str) config["model"]
    ai.set_config(url, key, model)
    print("成功加载配置并初始化 AI")
except Exception as e:
    print("警告：加载配置失败，错误: " + (str)e)
    # 模拟测试配置 (TESTONLY)
    # ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

str res = @~请说一句测试台词~
print("AI 回复: " + res)
