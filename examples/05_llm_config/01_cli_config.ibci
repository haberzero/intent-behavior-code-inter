import ai
import file
import json

# 情况 1：直接利用 main.py 提供的 --config 对外接口
# 
# 运行方式：
# python main.py run examples/05_llm_config/01_cli_config.ibci --config examples/05_llm_config/api_config.json
#
# main.py 会自动解析 json 中的 url, key, model 字段并注入为全局变量。

print("--- [01_cli_config.ibci] ---")

# 检查变量是否已由 main.py 注入
try:
    # 生产环境配置：使用注入的变量
    dict config = json.parse(file.read("api_config.json"))
    dict default_model = (dict) config["default_model"]
    str url = (str) default_model["base_url"]
    str key = (str) default_model["api_key"]
    str model = (str) default_model["model"]
    ai.set_config(url, key, model)
    print("成功使用 CLI 注入的配置初始化 AI")
except Exception as e:
    print("警告：未检测到 CLI 注入的配置变量，请确保使用了 --config 参数")
    # 模拟测试配置 (TESTONLY)
    # ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

str res = @~请说一句测试台词~
print("AI 回复: " + res)
