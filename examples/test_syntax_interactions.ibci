import ai
ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("=== 语法交互测试 ===")

# Test 1: @+ with LLM function
llm gen_reply(str input_text) -> str:
__sys__
Be concise.
__user__
"$input_text"
llmend

@+ 保持简洁
str llm_r = gen_reply("hello")
llmexcept:
    retry "answer"
@-
print("LLM func + @+: " + llm_r)

# Test 2: Intent scope inheritance in function calls
@+ outer scope intent
func inner_fn() -> str:
    str inner_r = @~ MOCK:STR:inner_result ~
    return inner_r
str fn_r = inner_fn()
@-
print("intent scope in fn: " + fn_r)

# Test 3: lambda + intent interaction
@+ lambda_intent
int lambda delayed = @~ MOCK:INT:99 ~
@-
# Call lambda - uses call-time intent (empty after @-)
int del_result = delayed()
print("lambda result (call-time intent): " + (str)del_result)

# Test 4: snapshot + intent interaction
@+ snapshot_intent
str snapshot snap_fn = @~ MOCK:STR:snapped ~
@-
str snap_result = snap_fn()
print("snapshot result (def-time intent): " + snap_result)

# Test 5: llmexcept inside loop with state
int iteration = 0
int success_count = 0
list[str] tasks = ["task1", "task2", "task3"]
for str task in tasks:
    iteration = iteration + 1
    str task_result = @~ MOCK:SEQ:[1,0,1] task_mock ~
    llmexcept:
        retry "please 0 or 1"
    if task_result == "1":
        success_count = success_count + 1
    print("Task " + task + ": " + task_result)
print("success_count: " + (str)success_count)

# Test 6: Deferred behavior passed to variable, then called
int lambda multiplier_fn = @~ MOCK:INT:7 multi_test ~
print("calling lambda...")
int multi_result = multiplier_fn()
print("lambda result: " + (str)multi_result)

# Test 7: Class with LLM + llmexcept
class SmartProcessor:
    int call_count
    
    func __init__(self):
        self.call_count = 0
    
    func analyze(self, str text) -> str:
        self.call_count = self.call_count + 1
        str analysis = @~ MOCK:STR:smart_analysis ~
        return analysis

SmartProcessor sp = SmartProcessor()
str a1 = sp.analyze("input1")
str a2 = sp.analyze("input2")
print("SmartProcessor call_count: " + (str)sp.call_count)
print("a1: " + a1)
print("a2: " + a2)

# Test 8: Multiple llmexcept blocks on sequential LLM calls
str r1 = @~ MOCK:REPAIR repair1 ~
llmexcept:
    retry "retry r1"

str r2 = @~ MOCK:REPAIR repair2 ~
llmexcept:
    retry "retry r2"

print("r1 (repair): " + r1)
print("r2 (repair): " + r2)

# Test 9: for...if with AI condition
list[str] words = ["hello", "world", "ibci", "test"]
list[str] filtered = []
for str w in words if @~ MOCK:SEQ:[1,0,1,0] filter_seq ~:
    filtered.append(w)
print("filtered words: " + (str)filtered)

print("=== 语法交互测试完成 ===")
