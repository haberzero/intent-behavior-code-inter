import ai
ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("=== 公理/OOP 系统测试 ===")

# 1. operator overloading
class Vec2:
    float x
    float y
    
    func __init__(self, float x, float y):
        self.x = x
        self.y = y
    
    func __add__(self, Vec2 other) -> Vec2:
        return Vec2(self.x + other.x, self.y + other.y)
    
    func __eq__(self, Vec2 other) -> bool:
        return self.x == other.x and self.y == other.y
    
    func __to_prompt__(self) -> str:
        return "Vec2(" + (str)self.x + "," + (str)self.y + ")"

Vec2 v1 = Vec2(1.0, 2.0)
Vec2 v2 = Vec2(3.0, 4.0)
Vec2 v3 = v1 + v2
print("v1 + v2 = " + v3.__to_prompt__())
print("v1 == v1: " + (str)(v1 == v1))
print("v1 == v2: " + (str)(v1 == v2))

# LLM interpolation uses __to_prompt__
str desc = @~ MOCK:STR:vec_desc ~
print("LLM used __to_prompt__: " + desc)

# 2. Multi-level inheritance
class Shape:
    str color
    
    func __init__(self, str c):
        self.color = c
    
    func area(self) -> float:
        return 0.0
    
    func describe(self) -> str:
        return "Shape[" + self.color + "] area=" + (str)(self.area())

class Circle(Shape):
    float radius
    
    func __init__(self, str c, float r):
        self.color = c
        self.radius = r
    
    func area(self) -> float:
        return 3.14159 * self.radius * self.radius

class Square(Shape):
    float side
    
    func __init__(self, str c, float s):
        self.color = c
        self.side = s
    
    func area(self) -> float:
        return self.side * self.side

Circle circ = Circle("red", 5.0)
Square sq = Square("blue", 4.0)
print(circ.describe())
print(sq.describe())

# 3. isinstance check
bool is_shape_c = circ is not None
bool is_shape_s = sq is not None
print("Circle instance OK: " + (str)is_shape_c)

# 4. class fields default values
class Config:
    int version = 1
    str name = "default"
    bool debug = false

Config cfg = Config()
print("Config.version: " + (str)cfg.version)
print("Config.name: " + cfg.name)
print("Config.debug: " + (str)cfg.debug)

# 5. Static-like pattern (class-level function as method)
class MathHelper:
    func square(self, int n) -> int:
        return n * n
    
    func cube(self, int n) -> int:
        return n * n * n

MathHelper mh = MathHelper()
print("square(7) = " + (str)(mh.square(7)))
print("cube(3) = " + (str)(mh.cube(3)))

print("=== 公理/OOP 系统测试完成 ===")
