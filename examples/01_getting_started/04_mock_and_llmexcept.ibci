# 04_mock_and_llmexcept.ibci
# IBCI 进阶：Mock 机制与 llmexcept 异常处理

# 本示例展示 IBCI 中的 Mock 机制和 llmexcept 异常处理：
# 1. Mock 机制 - 使用 MOCK: 前缀模拟 AI 响应
# 2. llmexcept - 处理 AI 调用失败或返回模糊结果
# 3. retry - 在 llmexcept 中显式触发重试

import ai
import file
import json
import idbg

# ============================================================
# 配置 AI（启用 Mock 模式）
# ============================================================

print("\n=== Mock 机制演示 ===\n")

ai.set_config(
    "TESTONLY",
    "TESTONLY",
    "TESTONLY"
)

print("使用 TESTONLY 模式启用 Mock")

# ============================================================
# Mock 指令格式说明
# ============================================================

print("\n=== Mock 指令格式 ===\n")

print("MOCK:TRUE [key]    - 返回 '1'")
print("MOCK:FALSE [key]   - 返回 '0'")
print("MOCK:FAIL [key]    - 返回模糊值，触发 llmexcept")
print("MOCK:REPAIR [key]  - 首次模糊，第二次成功")
print("MOCK:[...]         - 直接返回列表")
print("MOCK:{...}         - 直接返回字典")

# ============================================================
# 1. MOCK:TRUE / MOCK:FALSE
# ============================================================

print("\n=== 1. MOCK:TRUE / MOCK:FALSE ===\n")

str result1 = @~ MOCK:TRUE 是否晴朗？ ~
print("MOCK:TRUE 结果: " + result1)

str result2 = @~ MOCK:FALSE 是否下雨？ ~
print("MOCK:FALSE 结果: " + result2)

# ============================================================
# 2. MOCK:FAIL 触发 llmexcept
# ============================================================

print("\n=== 2. MOCK:FAIL 触发 llmexcept ===\n")

print("MOCK:FAIL 会返回模糊值，触发 llmexcept...")

int result3 = @~ MOCK:FAIL 请提取数字 ~
llmexcept:
    print("进入 llmexcept 处理块")
    print("模拟失败后重试...")
    retry "请只返回一个整数，如: 42"

print("提取结果: " + (str)result3)

# ============================================================
# 3. MOCK:REPAIR 模拟恢复
# ============================================================

print("\n=== 3. MOCK:REPAIR 模拟恢复 ===\n")

print("MOCK:REPAIR 首次返回模糊值，重试后返回确定值...")

str result4 = @~ MOCK:REPAIR simulate_recovery ~
llmexcept:
    print("首次尝试失败，进入 llmexcept")
    retry "REPAIR第二次尝试"

print("恢复结果: " + result4)

# ============================================================
# 4. MOCK:LIST / MOCK:DICT 直接返回结构（正确格式）
# ============================================================

print("\n=== 4. MOCK:LIST / MOCK:DICT 正确格式 ===\n")

# MOCK:LIST:[...] → list 类型可直接接收（Bug #2 不影响 list）
list fruits = @~ MOCK:LIST:["apple","banana","cherry"] ~
print("MOCK:LIST 返回的 list 长度: " + (str)fruits.len())
int fi = 0
while fi < fruits.len():
    print("  fruits[" + (str)fi + "] = " + (str)fruits[fi])
    fi = fi + 1

# MOCK:DICT → 已知 Bug #2：dict 类型变量接收 LLM 输出会产生类型错误
# 临时规避：使用 str 接收，原始字符串仍可查看
str raw_dict = @~ MOCK:DICT:{"name":"Alice","age":30} ~
print("MOCK:DICT 原始字符串: " + raw_dict)

# 通过 idbg 确认 LLM 调用详情（中间变量探查）
any last4 = idbg.last_llm()
print("idbg.last_llm() 含 MOCK:DICT 标记: " + (str)("MOCK:DICT" in (str)last4))

# ============================================================
# 5. llmexcept 与 idbg.last_result()
# ============================================================

print("\n=== 5. llmexcept 与 idbg.last_result() ===\n")

print("使用 idbg.last_result() 获取详细的 LLM 响应信息...")

str query = "hello"
print("查询: " + query)

str result7 = @~ MOCK:FAIL 请翻译 "$query" ~
llmexcept:
    any last_info = idbg.last_result()
    print("进入 llmexcept 处理块")
    print("idbg.last_result() raw_response: " + (str)last_info["raw_response"])
    print("idbg.last_result() success:      " + (str)last_info["success"])
    retry "请直接翻译为中文，不要其他文字"

print("翻译结果: " + (str)result7)

# ============================================================
# 6. llmretry 语法糖
# ============================================================

print("\n=== 6. llmretry 语法糖 ===\n")

# llmretry 是 llmexcept + retry 的单行语法糖
# MOCK:FAIL 永远失败，所以 result8 最终为 None（重试耗尽）
str result8 = @~ MOCK:FAIL 请回答问题 ~
llmretry "请只回复一个中文词语"

# 注意：result8 可能为 None（MOCK:FAIL 下重试耗尽），使用 (str) 安全转换
print("结果: " + (str)result8)

# 对比：使用 MOCK:REPAIR 演示 llmretry 成功的情况
str result9 = @~ MOCK:REPAIR 修复演示 ~
llmretry "重试提示"
print("REPAIR 后结果（应为 1）: " + (str)result9)

# ============================================================
# 7. 在流控中使用 Mock
# ============================================================

print("\n=== 7. 在流控中使用 Mock ===\n")

print("使用 MOCK:TRUE/FALSE 测试 if 条件...")

if @~ MOCK:TRUE 今天天气好吗？ ~:
    print("条件为真，进入 if 分支")
else:
    print("条件为假，进入 else 分支")

if @~ MOCK:FALSE 今天天气好吗？ ~:
    print("条件为真，进入 if 分支")
else:
    print("条件为假，进入 else 分支")

print("\n=== Mock 机制演示结束 ===\n")
