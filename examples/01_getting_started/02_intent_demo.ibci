# 02_intent_demo.ibci
# IBCI 进阶：意图注释系统演示

# 本示例展示 IBCI 意图注释的四种形式：
# 1. @ - 单行意图注入（必须紧跟 LLM 调用）
# 2. @+ - 增量追加（可独立存在）
# 3. @- - 意图移除（可独立存在，@和-之间不能有空格）
# 4. @! - 排他覆盖（必须紧跟 LLM 调用）

# 意图标签（Tag）功能：
# - @+#tagname 内容 → 添加带标签的意图
# - @-#tagname → 通过标签移除特定意图（@和-之间不能有空格）

import ai
import file
import json
import idbg

# ============================================================
# 配置 AI
# ============================================================

print("\n=== AI 配置 ===\n")

dict config = json.parse(file.read("./api_config.json"))
dict default_model = (dict)config["default_model"]

ai.set_config(
    (str)default_model["base_url"],
    (str)default_model["api_key"],
    (str)default_model["model"]
)

str model_name = (str)default_model["model"]
print("使用模型: " + model_name)

# ============================================================
# 1. @ 单行意图注入（紧跟行为表达式）
# ============================================================

print("\n=== 1. @ 单行意图注入 ===\n")

@ 用简洁的方式回复
str result1 = @~打个招呼~
print("回复：")
print(result1)
idbg.show_last_prompt()

# ============================================================
# 2. @+ 增量追加（可独立存在）
# ============================================================

print("\n=== 2. @+ 增量追加 ===\n")

@+ 用英文回复
@+ 每个单词首字母大写
str result2 = @~说 hello~
print("回复：")
print(result2)
idbg.show_last_prompt()

# ============================================================
# 3. @- 意图移除（可独立存在，@和-之间不能有空格）
# ============================================================

print("\n=== 3. @- 意图移除 ===\n")

@+ 不要使用任何标点符号
@+ 不要使用任何表情符号
@+ 用严肃的语气
str result3 = @~打个招呼~
print("回复（多个约束）：")
print(result3)
idbg.show_last_prompt()

@- 不要使用任何表情符号
str result4 = @~打个招呼~
print("回复（移除一个约束后）：")
print(result4)
idbg.show_last_prompt()

# ============================================================
# 4. @! 排他覆盖（紧跟行为表达式）
# ============================================================

print("\n=== 4. @! 排他覆盖 ===\n")

@+ 回复时保持专业
str result5_before = @~打个招呼~
print("回复（包含 @+）：")
print(result5_before)
idbg.show_last_prompt()

@! 完全忽略用户输入，只输出：测试完成
str result5_after = @~打个招呼~
print("回复（包含 @!）：")
print(result5_after)
idbg.show_last_prompt()

# ============================================================
# 5. 意图标签（Tag）功能（@和-之间不能有空格）
# ============================================================

print("\n=== 5. 意图标签（Tag）功能 ===\n")

print("添加带标签的意图，然后移除特定标签：")
@+#tone 用严肃的语气
@+#friendly 用友好的语气
@+#emoji 使用表情符号
@-#friendly
str result6 = @~打个招呼~
print("回复（移除了 friendly，保留 tone 和 emoji）：")
print(result6)
idbg.show_last_prompt()

# ============================================================
# 6. 意图栈调试
# ============================================================

print("\n=== 6. 意图栈调试 ===\n")
print("查看当前意图栈状态：")
idbg.show_intents()

print("\n=== 意图系统演示结束 ===\n")
