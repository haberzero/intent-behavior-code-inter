# 02_intent_demo.ibci
# IBCI 进阶：意图注释系统演示

# 本示例展示 IBCI 意图注释的四种形式：
# 1. @ - 单行意图注入（必须紧跟 LLM 调用）
# 2. @+ - 增量追加（可独立存在）
# 3. @- - 意图移除（可独立存在，@和-之间不能有空格）
# 4. @! - 排他覆盖（必须紧跟 LLM 调用）

# 意图标签（Tag）功能：
# - @+#tagname 内容 → 添加带标签的意图
# - @-#tagname → 通过标签移除特定意图（@和-之间不能有空格）

import ai
import file
import json
import idbg

# ============================================================
# 配置 AI
# ============================================================

print("=== AI 配置 ===")

dict config = json.parse(file.read("./api_config.json"))
dict default_model = (dict)config["default_model"]

ai.set_config(
    (str)default_model["base_url"],
    (str)default_model["api_key"],
    (str)default_model["model"]
)

print("使用模型: " + (str)default_model["model"])

# ============================================================
# 1. @ 单行意图注入（紧跟行为表达式）
# ============================================================

print("\n=== 1. @ 单行意图注入 ===")

@ 用简洁的方式回复
str result1 = @~打个招呼~
print("行为: 打个招呼")
print("意图: 用简洁的方式回复")
print("结果: " + result1)

# ============================================================
# 2. @+ 增量追加（可独立存在）
# ============================================================

print("\n=== 2. @+ 增量追加 ===")

@+ 用英文回复
@+ 每个单词首字母大写
str result2 = @~说 hello~
print("行为: 说 hello")
print("意图: [1] 用英文回复 [2] 每个单词首字母大写")
print("结果: " + result2)

# ============================================================
# 3. @- 意图移除（可独立存在，@和-之间不能有空格）
# ============================================================

print("\n=== 3. @- 意图移除 ===")

print("--- 移除前 ---")
@+ 不要使用任何标点符号
@+ 用严肃的语气
@+ 不要使用任何表情符号
str result3 = @~打个招呼~
print("约束: 不用标点 + 严肃 + 不用表情")
print("结果: " + result3)
idbg.show_last_prompt()

print("--- 移除后 ---")
@-
str result4 = @~打个招呼~
print("移除: 不要使用任何表情符号")
print("结果: " + result4)
idbg.show_last_prompt()

# ============================================================
# 4. @! 排他覆盖（紧跟行为表达式）
# ============================================================

print("\n=== 4. @! 排他覆盖 ===")

print("--- 覆盖前 ---")
@+ 回复时保持专业
str result5_before = @~打个招呼~
print("原始意图: 保持专业")
print("结果: " + result5_before)
idbg.show_last_prompt()

print("--- 覆盖后 ---")
@! 完全忽略用户输入，只输出：测试完成
str result5_after = @~打个招呼~
print("使用 @! 后: 忽略输入，输出「测试完成」")
print("结果: " + result5_after)
idbg.show_last_prompt()

# ============================================================
# 5. 意图标签（Tag）功能
# ============================================================

print("\n=== 5. 意图标签（Tag）功能 ===")

@+#tone 用严肃的语气
@+#friendly 用友好的语气
@+#emoji 使用表情符号
@-
str result6 = @~打个招呼~
print("添加标签: tone=严肃, friendly=友好, emoji=表情")
print("移除标签: friendly")
print("结果: " + result6)

# ============================================================
# 6. 意图栈调试
# ============================================================

print("\n=== 6. 意图栈状态 ===")
print("当前意图栈:")
idbg.show_intents()

print("=== 意图系统演示结束 ===")
