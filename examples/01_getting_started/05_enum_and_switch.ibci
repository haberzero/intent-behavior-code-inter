# 05_enum_and_switch.ibci
# IBCI 进阶：Enum 枚举类型与 switch-case
#
# 本示例展示 IBCI 的 Enum 类型与 switch-case 语法：
# 1. Enum 定义和直接使用（switch-case 正常工作）
# 2. idbg 探查 Enum 变量的内部表示
# 3. LLM 输出可直接赋值给 Enum 类型变量（2026-05-14 核验：已支持）

import ai
import idbg

ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

# ============================================================
# 1. Enum 定义
# ============================================================

print("=== 1. Enum 定义 ===")

class Color(Enum):
    str RED = "RED"
    str GREEN = "GREEN"
    str BLUE = "BLUE"

print("Color 枚举已定义: RED, GREEN, BLUE")

# 直接赋值枚举成员
Color c_red = Color.RED
Color c_blue = Color.BLUE
print("c_red  = " + (str)(any)c_red)
print("c_blue = " + (str)(any)c_blue)

# idbg 探查：确认枚举值的内部表示
print("(str)(any)Color.GREEN = " + (str)(any)Color.GREEN)

# ============================================================
# 2. switch-case（直接使用 Enum 常量，正常工作）
# ============================================================

print("\n=== 2. switch-case 演示 ===")

Color sky = Color.BLUE

print("sky 的值: " + (str)(any)sky)

switch sky:
    case Color.RED:
        print("  → 匹配到 RED")
    case Color.GREEN:
        print("  → 匹配到 GREEN")
    case Color.BLUE:
        print("  → 匹配到 BLUE（天空是蓝色的！）")
    default:
        print("  → 无匹配（不应出现）")

# ============================================================
# 3. Enum 比较与 if 条件
# ============================================================

print("\n=== 3. Enum 比较 ===")

bool is_blue = sky == Color.BLUE
bool is_red  = sky == Color.RED
print("sky == Color.BLUE: " + (str)is_blue)
print("sky == Color.RED:  " + (str)is_red)

# ============================================================
# 4. LLM 输出 → Enum 类型变量（已支持，2026-05-14 核验）
# ============================================================

print("\n=== 4. LLM 输出 → Enum（直接赋值）===")
print("说明：Enum 类型已实现完整的 __from_prompt__ / __outputhint_prompt__ 协议；")
print("LLM 输出的成员名（大小写不敏感）会被自动解析为对应 Enum 值。")
print("")

# LLM 返回颜色字符串（MOCK 模式下用 MOCK:STR:BLUE 模拟）
# 直接以 Enum 类型变量接收
Color llm_color = @~ MOCK:STR:BLUE ~

# idbg 确认 LLM 调用的 user_prompt 和 response
any last_info = idbg.last_llm()
print("idbg: user_prompt = " + (str)last_info["user_prompt"])
print("idbg: response    = " + (str)last_info["response"])
print("")

print("LLM 直接赋值给 Color 变量：llm_color == Color.BLUE? " + (str)(llm_color == Color.BLUE))

# Enum 变量可直接用于 switch
switch llm_color:
    case Color.RED:
        print("  → 识别为 RED")
    case Color.GREEN:
        print("  → 识别为 GREEN")
    case Color.BLUE:
        print("  → 识别为 BLUE（直接赋值成功）")
    default:
        print("  → 未知颜色")

# ============================================================
# 5. MOCK:SEQ 模拟多次 LLM 调用
# ============================================================

print("\n=== 5. MOCK:SEQ 遍历颜色 ===")

list color_names = ["RED", "GREEN", "BLUE", "RED"]
int ci = 0
while ci < color_names.len():
    str expected = (str)color_names[ci]
    print("  第 " + (str)ci + " 次：处理颜色 " + expected)
    ci = ci + 1

print("\n=== Enum + Switch 演示结束 ===")

