# 01_hello_ai.ibci
# IBCI 入门：行为描述 + AI 交互
#
# 本示例展示 IBCI 的核心特性：
# 1. 行为描述语句 - 用 @~...~ 语法直接调用 AI
# 2. LLM 函数 - 用 llm 关键字定义 AI 函数
# 3. 意图注释 - 用 #@ 让 AI 理解代码意图

import ai
import file
import json
import sys

print("=== IBCI 入门：你好，AI 世界 ===")

# ============================================================
# 第一部分：配置 AI
# ============================================================

print("\n--- AI 配置 ---")

# 加载 API 配置
str config_path = (str)sys.script_dir() + "/api_config.json"
dict config = json.parse(file.read(config_path))
dict default_model = (dict)config["default_model"]

# 配置 AI 提供者
ai.set_config(
    (str)default_model["base_url"],
    (str)default_model["api_key"],
    (str)default_model["model"]
)

str model_name = (str)default_model["model"]
print("使用模型: " + model_name)

# ============================================================
# 第二部分：行为描述语句
# ============================================================

print("\n--- 行为描述语句 ---")

#@ 用户问候
str greeting = "Hello, World!"
print(greeting)

#@ 计算两个数的和
int a = 10
int b = 20
int sum = a + b
print("10 + 20 = " + (str)sum)

# ============================================================
# 第三部分：直接 AI 调用
# ============================================================

print("\n--- 直接 AI 调用 ---")

#@ 设置 AI 角色
@ 你现在是一个幽默的编程助手

#@ 向 AI 提问（使用 @~...~ 语法）
str response = @~请用一句话介绍 IBCI 编程语言~
print("AI 回答: " + response)

#@ 让 AI 生成一首小诗
str poem = @~请用中文写一首关于编程的小诗，不超过20字~
print("\nAI 创作的诗:")
print(poem)

# ============================================================
# 第四部分：LLM 函数
# ============================================================

print("\n--- LLM 函数 ---")

# 定义一个翻译函数
llm 翻译(str 文本):
    __sys__
    你是一个简洁的中英文翻译助手，只返回翻译结果。
    __user__
    请将以下内容翻译成英文：$文本
llmend

str chinese_text = "编程让世界更美好"
str english_text = 翻译(chinese_text)
print("原文: " + chinese_text)
print("翻译: " + english_text)

# ============================================================
# 第五部分：意图注释的作用
# ============================================================

print("\n--- 意图注释 ---")

#@ 计算购物车总价
#@ 输入：商品价格列表
#@ 输出：总价
list prices = [29.9, 49.9, 19.9]
float total = 0.0
int i = 0
while i < prices.len():
    total = total + (float)prices[i]
    i = i + 1

print("购物车总价: $" + (str)total)

print("\n=== 完成 ===")
print("IBCI 将行为描述与 AI 能力完美结合！")
