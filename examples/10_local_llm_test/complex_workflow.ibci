import ai
import file
import idbg
import json

# 配置本地 LLM
# url, key, model 由 main.py 从 api_config.json 自动注入为全局变量
ai.set_config(url, key, model)

# 为小模型优化提示词：增强约束和输出格式引导
ai.set_branch_prompt("你是一个精准的布尔逻辑判定专家。请基于用户提供的内容，如果条件成立请返回 1，否则返回 0。严禁输出任何多余的文字、标点或解释。")
ai.set_return_type_prompt("dict", "请返回一个严格符合 JSON 格式的对象。禁止包含 Markdown 代码块标记。")

# 1. 定义结构化日志分析函数
llm 分析日志(str 日志行) -> dict:
    __sys__
    你是一个系统运维专家。请分析以下日志行并提取关键信息。
    
    __user__
    日志内容: $__日志行__
    
    请输出 JSON 格式:
    - level: 日志级别 (ERROR, INFO, WARNING)
    - timestamp: 时间戳
    - message: 核心错误信息简述
llmend

print("--- [10_local_llm_test/complex_workflow.ibci] ---")

# 2. 准备测试数据
str log_path = "system.log"
file.write(log_path, "[2026-03-11 10:00:01] INFO: System started.\n[2026-03-11 10:05:22] ERROR: Connection refused to database.\n[2026-03-11 10:08:45] WARNING: Disk usage is 85%.")

list lines = ["INFO: System started.", "ERROR: Connection refused to database.", "WARNING: Disk usage is 85%."]

# 3. 复杂工作流：意图叠加与自动容错
intent "目标：发现并总结所有致命错误":
    for line in lines:
        # 判定是否为严重错误
        # 对于小模型，我们使用 llmexcept 处理它的犹豫
        if @~ 这一行日志 '$line' 是否属于需要立即处理的 ERROR 级别错误？ ~:
            print("\n发现严重错误: " + line)
            
            # 调用结构化分析
            dict info = 分析日志(line)
            print("解析结果 -> 级别: " + info["level"] + ", 信息: " + info["message"])
            
            # 使用 idbg 观测最后一次 AI 响应
            dict last_call = idbg.last_llm()
            print("[DEBUG] AI 原始响应: " + last_call["response"])
        llmexcept:
            print("\n[AI 犹豫不决] 正在尝试引导模型进行二选一判定: " + line)
            retry "请仅回答 1 (是错误) 或 0 (不是错误)"

print("\n--- 工作流执行完毕 ---")
