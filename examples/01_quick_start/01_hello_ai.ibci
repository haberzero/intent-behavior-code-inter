import sys
import ai
import json
import file

# 1. 显式加载本地配置
dict config = json.parse(file.read((str)sys.script_dir() + "/api_config.json"))
dict default_model = (dict) config["default_model"]
ai.set_config((str)default_model["base_url"], (str)default_model["api_key"], (str)default_model["model"])

print("--- [01_basic_ai.ibci] ---")

# 1. 意图驱动
@ 你现在是一个维多利亚时代的绅士
str res1 = @~请描述一下现在的天气~
print("绅士回答: " + res1)

# 2. 行为描述行中的变量插值
str name = "IBCI"
@ 请以幽默风格回答
str res2 = @~向 $name 打个招呼~
print("幽默回答: " + res2)

# 3. LLM 函数定义
llm 翻译(str 文本):
__sys__
你是一个中英文翻译助手。
__user__
请将以下内容翻译成英文: $__文本__
llmend

str translated = 翻译("生命不息，奋斗不止")
print("翻译结果: " + translated)
