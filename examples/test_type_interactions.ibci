import ai
ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("=== 类型系统交互测试 ===")

# 1. auto type inference
auto x = 42
print("auto int: " + (str)x)

auto y = "hello"
print("auto str: " + y)

auto z = @~ MOCK:STR:auto_behavior ~
print("auto @~ ~: " + (str)z)

# 2. fn type
func add(int a, int b) -> int:
    return a + b

fn f = add
int res = f(3, 4)
print("fn call: " + (str)res)

# 3. any type
any a = 42
any b = "hello"
any c = [1, 2, 3]
print("any int: " + (str)a)
print("any str: " + (str)b)
print("any list: " + (str)c)

# 4. Casting between types
int ci = 42
float cf = (float)ci
bool cb = (bool)ci
str cs = (str)ci
print("int→float: " + (str)cf)
print("int→bool: " + (str)cb)
print("int→str: " + cs)

float ff = 3.7
int fi = (int)ff
print("float→int: " + (str)fi)

str ss = "100"
int si = (int)ss
print("str→int: " + (str)si)

str sf_str = "3.14"
float sff = (float)sf_str
print("str→float: " + (str)sff)

# 5. Generic types
list[int] ints = [1, 2, 3]
list[str] strs = ["a", "b", "c"]
dict[str,int] d = {"x": 1, "y": 2}

print("list[int]: " + (str)ints)
print("list[str]: " + (str)strs)

# 6. Nested generics
list[list] nested = [[1, 2], [3, 4]]
any inner = nested[0]
print("nested[0]: " + (str)inner)

# 7. Callable type
class Counter:
    int count
    func __init__(self):
        self.count = 0
    func __call__(self, int n) -> int:
        self.count = self.count + n
        return self.count

Counter ctr = Counter()
int r1 = ctr(5)
int r2 = ctr(3)
print("counter after 5+3: " + (str)r2)

# 8. Multiple assignment
int m1 = 1
int m2 = 2
m1 = m1 + m2
print("m1 = " + (str)m1)

print("=== 类型系统交互测试完成 ===")
