import ai
import json
import file

# 1. 加载配置
dict config = json.parse(file.read("api_config.json"))
dict default_model = config["default_model"]
str url = default_model["base_url"]
str key = default_model["api_key"]
str model = default_model["model"]

ai.set_config(url, key, model)

# 2. 模拟测试配置 (TESTONLY)：如果无法连接真实 LLM，请取消注释以下行
# ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("--- [01_basic_ai.ibci] ---")

# 1. 意图驱动
@ 你现在是一个维多利亚时代的绅士
str res1 = @~请描述一下现在的天气~
print("绅士回答: " + res1)

# 2. 行为描述行中的变量插值
str name = "IBCI"
@ 请以幽默风格回答
str res2 = @~向 $name 打个招呼~
print("幽默回答: " + res2)

# 3. LLM 函数定义
llm 翻译(str 文本):
__sys__
你是一个中英文翻译助手。
__user__
请将以下内容翻译成英文: $__文本__
llmend

str translated = 翻译("生命不息，奋斗不止")
print("翻译结果: " + translated)
