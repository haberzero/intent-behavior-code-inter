import sys
import json
import file
import ai
import file
import json
import idbg

# 1. 模拟测试配置 (TESTONLY)

dict config = json.parse(file.read((str)sys.script_dir() + "/api_config.json"))
dict default_model = (dict) config["default_model"]
ai.set_config((str)default_model["base_url"], (str)default_model["api_key"], (str)default_model["model"])


# 2. 模拟测试配置 (TESTONLY)

dict config = json.parse(file.read((str)sys.script_dir() + "/api_config.json"))
dict default_model = (dict) config["default_model"]
ai.set_config((str)default_model["base_url"], (str)default_model["api_key"], (str)default_model["model"])


print("--- [07_idbg/interactive_debug.ibci] ---")

# 1. 变量快照 (idbg.vars)
int count = 10
str message = "Hello, IDBG!"

dict vars_snap = idbg.vars()
print("\n[idbg.vars] 变量快照 (访问 .value):")
# idbg.vars() 返回的 dict 每个元素包含 {value, type, metadata, is_const}
print("count: " + (str)vars_snap["count"])
print("message: " + (str)vars_snap["message"])

# 2. 运行时环境信息 (idbg.env)
ai.set_global_intent("调试意图：追踪执行流")
intent "场景：单元测试":
    dict env_snap = idbg.env()
    print("\n[idbg.env] 环境信息:")
    print("指令计数: " + (str)env_snap["instruction_count"])
    # active_intents 仅包含通过 intent 块或 @ 注入的动态意图
    print("活跃意图数量: " + (str)env_snap["active_intents"])

# 3. LLM 最后一次调用信息 (idbg.last_llm)
# 在真实 LLM 下，这通常会产生一个正常的 1/0 判定。
if @~ 判定 1+1 是否等于 2？请直接回答 1 或 0。 ~:
    print("\n[LLM] 判断正确！")
llmexcept:
    print("\n[llmexcept] 捕获到模糊判断，正在重试...")
    retry "请直接回答 1 或 0"

dict last_call = idbg.last_llm()
print("\n[idbg.last_llm] 最后一次 LLM 调用细节:")
print("系统提示词片段: " + (str)last_call["sys_prompt"])
print("AI 原始响应: " + (str)last_call["response"])

# 4. 对象内部细节 (idbg.fields)
class Person:
    str name = "Alice"
    int age = 30

var p = Person()
dict fields = idbg.fields(p)
print("\n[idbg.fields] 对象字段详情:")
print("name: " + (str)fields["name"])
print("age: " + (str)fields["age"])
