import ai
import file
import json

# 1. 生产环境配置
dict config = json.parse(file.read("api_config.json"))
dict default_model = (dict) config["default_model"]
str url = (str) default_model["base_url"]
str key = (str) default_model["api_key"]
str model = (str) default_model["model"]
ai.set_config(url, key, model)

# 2. 模拟测试配置 (TESTONLY)
# ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("--- [02_llm_error_handling.ibci] ---")

# 1. 使用 llmexcept 处理 LLM 判断不明确的情况
# 在真实 LLM 下，这通常会在 AI 给出长篇大论而不是 1/0 时触发。
if @~ 检查今天的天气是否适合户外野餐？请直接回答 1 (适合) 或 0 (不适合)。 ~:
    print("AI 建议：天气非常适合！")
else:
    print("AI 建议：天气不适合，建议待在室内。")
llmexcept:
    print("AI 返回判断模糊，正在启动重试机制...")
    # 注入重试提示词，引导 AI 给出确定性回答
    # retry 语句会携带此 hint 重新发起请求
    retry "请务必只返回 1 或 0，不要包含任何解释文字"

# 2. 循环中的 AI 判断
int count = 0
while @~ 判定当前任务是否还需要继续？请回答 1 或 0。 ~:
    count = count + 1
    print("正在执行第 " + (str)count + " 次任务")
    if count >= 2:
        # 手动退出或改变环境状态
        break
llmexcept:
    print("循环判断模糊，任务强制中止。")

# 3. 混合 try-except 捕获普通运行时错误
try:
    int x = 10 / 0
except Exception as e:
    print("\n捕获到普通运行时错误: " + (str)e)
finally:
    print("清理工作已完成。")
