import ai

# 1. 生产环境配置
ai.set_config(url, key, model)

# 2. 模拟测试配置 (TESTONLY)：如果使用模拟模式，AI 将识别 MOCK:1/0/REPAIR 指令
# ai.set_config("TESTONLY", "TESTONLY", "TESTONLY")

print("--- [intent_driven_loop.ibci] ---")

# 1. 基础意图驱动循环
int count = 0
str status = "还需要继续处理数据"

print("开始意图驱动循环...")
# 在真实模式下，AI 会分析 $status 的含义。
# 如果切换到 MOCK 模式，请将 status 改为 "MOCK:1"
for @~ 检查当前状态 '$status'。如果认为任务需要继续请返回 1，否则返回 0。 ~:
    count = count + 1
    print("执行中... 当前次数: " + (str)count)
    if count >= 3:
        status = "任务已完成，可以停止"
        print("已达到目标，修改状态以引导 AI 停止。")

print("循环结束，总计次数: " + (str)count)

# 2. 带容错的意图驱动循环
print("\n测试带容错的意图循环...")
int b_count = 0

# 提示：在真实 LLM 下，如果你想测试 llmexcept 逻辑，可以尝试给出一个极其模糊的指令
# 在 MOCK 模式下，可以使用 @~ MOCK:REPAIR ... ~
for @~ 判定是否需要继续执行？请给出一个确定的 1 或 0。 ~:
    b_count = b_count + 1
    print("执行中... b_count = " + (str)b_count)
    if b_count >= 2:
        break
llmexcept:
    print("AI 判断模糊，正在通过 llmexcept 进行重试修正...")
    retry "请务必只返回 1 或 0，不要有任何废话"

print("测试完成。")
