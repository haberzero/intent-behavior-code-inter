# 1. 结构化分析函数 (llm ... llmend)
llm 分析文档(str 文档内容, str 分析重点) -> dict:
    __sys__
    你是一个专业的文档分析专家。
    请分析用户提供的文档内容，并根据指定的分析重点生成一份结构化的 JSON 报告。
    
    __user__
    文档内容如下:
    ---
    $__文档内容__
    ---
    
    分析重点: $__分析重点__
    
    请输出以下字段:
    - title: 文档标题 (str)
    - summary: 核心摘要 (str)
    - key_points: 关键点列表 (list)
    - entities: 文档中涉及的主要实体 (list)
llmend

# 2. 意图驱动的文件处理
str sample_path = "sample_doc.txt"
file.write(sample_path, "标题：量子纠缠研究报告\n内容：量子纠缠是一种奇特的物理现象，涉及两个或多个粒子之间的非局域关联。")

print("--- [08_complex_llm/doc_analyzer.ibci] ---")

if file.exists(sample_path):
    str content = file.read(sample_path)
    
    # 在真实环境下，AI 会直接分析文档并返回结构化数据。
    @ 侧重：物理学意义
    dict report = 分析文档(content, "提取核心概念和历史背景")
    
    print("\n[AI 分析报告]:")
    print("标题: " + report["title"])
    print("摘要: " + report["summary"])
    
    # 4. 容错处理
    if @~ 检查报告是否完整且包含量子纠缠的描述？请回答 1 或 0。 ~:
        print("\n报告完整性校验通过。")
    llmexcept:
        print("\n[容错] 报告完整性判定不明确，正在进行重试...")
        retry "请回答 1 或 0"

print("\n--- 分析任务完成 ---")
