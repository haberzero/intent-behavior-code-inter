# 测试 llmexcept 挂载逻辑

import ai
ai.set_config("TESTONLY", "MOCK_KEY", "MOCK_MODEL")

print("=== 测试 1: if + @~ + llmexcept ===")
if @~ MOCK:REPAIR 测试1 ~:
    print("条件成立")
llmexcept:
    print("llmexcept 被触发")
    retry "请重试"

print("=== 测试 2: 独立的 llmexcept retry ===")
@~ MOCK:FAIL 测试2 ~
llmexcept:
    retry "请重试"

print("=== 测试完成 ===")
