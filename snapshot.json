      "inst_524f992f": {
        "uid": "inst_524f992f",
        "class_name": "str",
        "_type": "primitive",
        "value": "\nimport host\n\nprint(\"--- Starting Dynamic Host Verification ---\")\n\n# 1. 元编程：获取源码\nstr source = host.get_source()\nint src_len = len(source)\nprint(\"Self source length: \" + (str)src_len)\nif src_len > 0:\n    print(\"PASS: get_source()\")\nelse:\n    print(\"FAIL: get_source() returned empty\")\n\n# 2. 运行时持久化\nprint(\"Testing save/load state...\")\nint val = 100\nhost.save_state(\"snapshot.json\")\n\nval = 200 # 修改状态\nprint(\"Value before load: \" + (str)val)\n\nhost.load_state(\"snapshot.json\")\n# 注意：load_state 会覆盖当前解释器的上下文，所以变量 'val' 应该恢复\nprint(\"Value after load (should be 100): \" + (str)val)\n\nif val == 100:\n    print(\"PASS: save_state/load_state\")\nelse:\n    print(\"FAIL: state not restored\")\n\n# 3. 隔离执行\nprint(\"Testing isolated run...\")\n# 隔离子脚本\ndict policy = {\"inherit_plugins\": [\"sys\", \"math\"], \"inherit_intents\": 1}\nbool success = host.run(\"sub_script.ibci\", policy)\n\nif success:\n    print(\"PASS: isolated run()\")\nelse:\n    print(\"FAIL: isolated run() failed\")\n\nprint(\"--- Verification Complete ---\")"
      },
