import ai
import idbg
import json
import file
import sys

# 1. 初始化：混合使用真实配置与调试模式
dict config = (dict) json.parse(file.read((str)sys.script_dir() + "/api_config.json"))
dict default_model = (dict) config["default_model"]
ai.set_config((str)default_model["base_url"], (str)default_model["api_key"], (str)default_model["model"])
ai.set_timeout(60.0)

print("=== IBC-Inter Comprehensive Feature Test ===")

# --- [模块 1] 模型探测与环境感知 ---
print("\n[Phase 1] Model Probing & IDBG Inspection:")
str probe_res = ai.probe_model()
print("  => Probe Result: " + probe_res)

# 利用 idbg 检查探测请求的细节
any probe_info = (any) idbg.last_llm()
print("  [IDBG] Probe System Prompt: " + (str)probe_info["sys_prompt"])

# --- [模块 2] 复杂意图注入与关键字提取 ---
print("\n[Phase 2] Intent Injection & Structured Extraction:")

# 注入全局约束
ai.set_global_intent("请始终使用 JSON 格式回复，字段名为 'result'")

llm extract_keywords(str text) -> str:
    __sys__
    你是一个关键词提取专家。
    __user__
    请提取这段话的 3 个核心词：$text
llmend

str target_text = "IBCI 2.0 引入了影子执行拦截器，通过 Result Mode 彻底解决了 LLM 调用中的不确定性自愈问题。"
str keywords = extract_keywords(target_text)

# 校验提取结果，演示 llmretry 语法糖
if @~ 校验 [keywords] 是否包含 '影子执行' 和 'Result Mode'？ ~:
    print("  => Keywords validated: " + keywords)
llmretry "提取结果不符合要求，请重新提取并确保包含核心架构名词。"

# --- [模块 3] 高级控制流与元组解包 ---
print("\n[Phase 3] Advanced Control Flow (For Loops):")

list tasks = [["Task A", 1], ["Task B", 0], ["Task C", 1]]
for (str name, int status) in tasks:
    if status == 1:
        print("  Executing: " + name)
    else:
        print("  Skipping: " + name)

# --- [模块 4] 模拟故障自愈 (Mock Mode) ---
print("\n[Phase 4] Mock Failure & IDBG Retry Stack:")

# 临时切换到 Mock 模式模拟模糊输出
ai.set_config("TESTONLY", "MOCK_KEY", "mock-model")

if @~ MOCK:REPAIR simulate_recovery ~:
    print("  => Logic recovered successfully.")
llmexcept:
    # 在 llmexcept 块中利用 idbg 深度洞察
    any last_res = (any) idbg.last_result()
    print("  [IDBG] Uncertain response received: " + (str)last_res["raw_response"])
    
    list stack = idbg.retry_stack()
    if stack.len() > 0:
        any frame = (any) stack[0]
        print("  [IDBG] Current Retry Count: " + (str)frame["retry"])
    
    retry "AI 响应模糊，请返回确定值 1。"

print("\n=== Comprehensive Test Complete ===")
